// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum GroupOrderStatus {
  OPEN
  CLOSED
  COMPLETED
  CANCELLED
}

enum ReservationStatus {
  RESERVED
  PAID
  CANCELLED
}

model User {
  id        Int      @id @default(autoincrement())

  username  String
  email     String   @unique
  password  String

  phone     String?
  avatar    String?

  role      UserRole @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations Reservation[]
}


model KpopGroup {
  id          Int      @id @default(autoincrement())

  name        String   @unique
  memberCount Int
  imageUrl String?

  createdAt   DateTime @default(now())

  members Member[]
  albums Album[]
}


model Member {
  id        Int @id @default(autoincrement())

  name      String

  imageUrl  String?

  groupId   Int
  group     KpopGroup @relation(fields: [groupId], references: [id])

  slots GroupOrderSlot[]
}


model Album {
  id Int @id @default(autoincrement())

  name String

  version String?

  coverImage String?

  releaseDate DateTime?

  groupId Int
  group KpopGroup @relation(fields: [groupId], references: [id])

  groupOrders GroupOrder[]
}


model Store {
  id Int @id @default(autoincrement())

  name String @unique

  logo String?

  groupOrders GroupOrder[]
}


model GroupOrder {
  id Int @id @default(autoincrement())

  title String

  pobEvent String

  albumId Int
  album Album @relation(fields: [albumId], references: [id])

  storeId Int
  store Store @relation(fields: [storeId], references: [id])

  price Decimal @db.Decimal(10,2)

  deadline DateTime

  totalSlots Int

  reservedSlots Int @default(0)

  notes String?

  status GroupOrderStatus @default(OPEN)

  createdAt DateTime @default(now())

  slots GroupOrderSlot[]
}


model GroupOrderSlot {

  id Int @id @default(autoincrement())

  groupOrderId Int
  groupOrder GroupOrder @relation(fields:[groupOrderId], references:[id])

  memberId Int
  member Member @relation(fields:[memberId], references:[id])

  reservation Reservation?
}


model Reservation {

  id Int @id @default(autoincrement())

  userId Int
  user User @relation(fields:[userId], references:[id])

  slotId Int @unique
  slot GroupOrderSlot @relation(fields:[slotId], references:[id])

  status ReservationStatus @default(RESERVED)

  createdAt DateTime @default(now())
}
